# Copy this file to .env on the server and fill operational values there.
# Do not commit .env, Slack tokens, signing secrets, or other secrets.
# Ollama runs as a separate compose service on the external homeserver network.

APP_ENV=production
LOG_LEVEL=INFO
AI_FEED_BOT_IMAGE=ghcr.io/<owner>/ai-feed-bot:latest

AI_FEED_DB_PATH=/data/ai-feed.db
AI_FEED_ENABLE_SLACK=false
AI_FEED_ENABLE_WORKER=true
AI_FEED_ENABLE_WEB=true
AI_FEED_WEB_HOST=0.0.0.0
AI_FEED_WEB_PORT=8000

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b
AI_FEED_FETCH_INTERVAL_MINUTES=60
