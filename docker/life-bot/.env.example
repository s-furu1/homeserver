# Copy this file to .env on the server and fill operational values there.
# Do not commit .env, Slack tokens, signing secrets, or Google credentials.

APP_ENV=production
LOG_LEVEL=INFO
LIFE_BOT_IMAGE=ghcr.io/<owner>/life-bot:latest

LIFE_DB_PATH=/data/life.db
LIFE_WEB_HOST=0.0.0.0
LIFE_WEB_PORT=8000
LIFE_MONEY_WEB_URL=
LIFE_ENABLE_SLACK=false
LIFE_ENABLE_WORKER=false
LIFE_TIMEZONE=Asia/Tokyo
LIFE_BACKUP_DIR=/backup
LIFE_BACKUP_RETENTION_DAYS=14

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_LIFE_MONEY=
SLACK_CHANNEL_LIFE_TASK=
SLACK_CHANNEL_LIFE_RUNNING=
SLACK_CHANNEL_LIFE_CALENDAR=
SLACK_CHANNEL_LIFE_ALERT=
SLACK_CHANNEL_AI_FEED=
SLACK_CHANNEL_SERVER_REPORT=
SLACK_CHANNEL_SERVER_ALERT=

AI_FEED_BASE_URL=http://ai-feed-bot:8000
DAILY_REPORT_BASE_URL=http://daily-report-bot:8000

HEALTH_WEBHOOK_TOKEN=

GOOGLE_CALENDAR_ID=
# Path inside the container to the service account JSON mounted from ./secrets.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-calendar-service-account.json
