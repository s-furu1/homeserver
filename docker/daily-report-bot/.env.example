# Copy this file to .env on the server and fill operational values there.
# Do not commit .env, GitHub tokens, Slack tokens, or signing secrets.

APP_ENV=production
LOG_LEVEL=INFO
DAILY_REPORT_BOT_IMAGE=ghcr.io/<owner>/daily-report-bot:latest

DAILY_REPORT_DB_PATH=/data/daily-report.db
DAILY_REPORT_ENABLE_SLACK=false
DAILY_REPORT_ENABLE_WORKER=true
DAILY_REPORT_ENABLE_WEB=true
DAILY_REPORT_WEB_HOST=0.0.0.0
DAILY_REPORT_WEB_PORT=8000
DAILY_REPORT_TIMEZONE=Asia/Tokyo
DAILY_REPORT_DAILY_HOUR=8
DAILY_REPORT_DAILY_MINUTE=0
DAILY_REPORT_WEEKLY_DAY=SUN
DAILY_REPORT_WEEKLY_HOUR=20
DAILY_REPORT_WEEKLY_MINUTE=0

GITHUB_TOKEN=
